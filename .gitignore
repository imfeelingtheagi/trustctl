# Build artifacts
/bin/
/dist/
/site/

# Bare `go build ./cmd/...` binaries dropped at the repo root. The Makefile
# builds into dist/; these are stray local builds and must never be committed.
/trustctl
/trustctl-agent
/trustctl-cli
/trustctl-signer

# Web UI: dependencies and the built assets (regenerated by `make web` / Vite).
# The committed placeholder index.html under internal/webui/dist keeps the Go
# //go:embed valid before a build.
/web/node_modules/
/internal/webui/dist/*
!/internal/webui/dist/index.html

# Test and coverage output
*.out
*.test
coverage.*
/coverage/

# Go workspace files (not committed; per-developer)
go.work
go.work.sum

# Editor / OS cruft
.DS_Store
*.swp
*~
.idea/
.vscode/
