  "info": {
    "description": "Resource-oriented REST API for trustctl. Mutations require an Idempotency-Key; errors are RFC 7807 problem+json; lists use cursor pagination.",
    "title": "trustctl API",
    "version": "v1"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/agents": {
      "get": {
        "operationId": "listAgents",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentList"
                }
              }
            },
            "description": "success"
          },
          "4XX": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "client error"
          },
          "5XX": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "server error"
          }
        },
        "summary": "List in-network agents"
      }
    },
    "/api/v1/agents/enrollment-tokens": {
      "post": {
        "operationId": "createEnrollmentToken",
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EnrollmentToken"
                }
              }
            },
            "description": "success"
          },
          "4XX": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "client error"
          },
          "5XX": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "server error"
          }
        },
        "summary": "Mint a one-time agent bootstrap token"
      }
    },
    "/api/v1/audit/events": {
      "get": {
        "operationId": "searchAudit",
        "parameters": [
          {
            "description": "comma-separated event types to include",
            "in": "query",
            "name": "type",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "RFC3339 inclusive lower time bound",
            "in": "query",
            "name": "since",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "RFC3339 inclusive upper time bound",
            "in": "query",
            "name": "until",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "point-in-time: only events with sequence \u003c= this",
            "in": "query",
            "name": "as_of",
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "substring match on event type or data",
            "in": "query",
            "name": "q",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "maximum records to return",
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditEventList"
                }
              }
            },
            "description": "success"
          },
          "4XX": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "client error"
          },
          "5XX": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "server error"
          }
        },
        "summary": "Query the audit log"
      }
    },
    "/api/v1/audit/export": {
      "get": {
        "operationId": "exportAudit",
        "parameters": [
          {
            "description": "comma-separated event types to include",
            "in": "query",
            "name": "type",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "RFC3339 inclusive lower time bound",
            "in": "query",
            "name": "since",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "RFC3339 inclusive upper time bound",
            "in": "query",
            "name": "until",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "point-in-time: only events with sequence \u003c= this",
            "in": "query",
            "name": "as_of",
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "substring match on event type or data",
            "in": "query",
            "name": "q",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "maximum records to return",
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditBundle"
                }
              }
            },
            "description": "success"
          },
          "4XX": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "client error"
          },
          "5XX": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "server error"
          }
        },
        "summary": "Export a signed audit evidence bundle"
      }
    },
    "/api/v1/certificates": {
      "get": {
        "operationId": "listCertificates",
        "parameters": [
          {
            "description": "maximum items per page (1-100, default 20)",
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "opaque pagination cursor from a prior page",
            "in": "query",
            "name": "cursor",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "RFC3339; return only certificates expiring before this time",
            "in": "query",
            "name": "expiring_before",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CertificateList"
                }
              }
            },
