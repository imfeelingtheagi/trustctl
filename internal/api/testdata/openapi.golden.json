    "/api/v1/graph/query": {
      "post": {
        "operationId": "graphQuery",
        "responses": {
          "200": {
            "description": "success"
          },
          "4XX": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
