              }
            },
            "description": "client error"
          },
          "5XX": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "server error"
          }
        },
        "summary": "Get an inventoried certificate"
      }
    },
    "/api/v1/graph": {
      "get": {
        "operationId": "getGraph",
        "responses": {
          "200": {
